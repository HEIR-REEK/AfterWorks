# Copy this file to .env and configure each variable

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL (production recommended)
DATABASE_URL="postgresql://user:password@localhost:5432/afterworks"

# OR SQLite for local development (auto-creates dev.db)
# DATABASE_URL="file:./dev.db"

# ============================================================================
# FIREBASE AUTHENTICATION
# ============================================================================
# Download service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key

# For HOSTED environments (Render, Vercel, etc.): paste the full JSON as a single-line string.
# This is the RECOMMENDED approach for Render deployment.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# For LOCAL development: point to the file on disk instead.
FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccountKey.json"
# Firebase web app configuration (safe to expose; do not use Admin credentials here)
FIREBASE_WEB_API_KEY=AIza...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=1:123456789:web:abcdef

# ============================================================================
# PAYSTACK PAYMENT GATEWAY
# ============================================================================
# Get from: https://paystack.co → Settings → API Keys & Webhooks
# Test mode (recommended for development)
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx

# Live mode (production only)
# PAYSTACK_SECRET_KEY=sk_live_xxxxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxxxx

# Training fee amount in cents ($10 USD = 1000 cents)
PAYSTACK_TRAINING_AMOUNT=1000

# Paystack API base URL (do not modify)
PAYSTACK_BASE_URL=https://api.paystack.co

# ============================================================================
# TWILIO VERIFY (SMS PHONE VERIFICATION)
# ============================================================================
# Create a Verify service in the Twilio Console. Phone numbers must be E.164.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_secret
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# ACCURA SCAN ABIS (KYC)
# ============================================================================
# Populate these from Accura Scan's issued API contract. Do not expose them to clients.
ACCURASCAN_API_URL=https://provider-issued-url
ACCURASCAN_API_KEY=replace_with_secret
ACCURASCAN_WEBHOOK_SECRET=replace_with_secret

# ============================================================================
# DIDIT PROTOCOL (KYC & IDENTITY VERIFICATION)
# ============================================================================
# Obtain keys and configuration from Didit Business Console (https://didit.me)
# Base URL defaults to https://apx.didit.me (or sandbox endpoint)
DIDIT_API_URL=https://apx.didit.me
DIDIT_CLIENT_ID=your_didit_client_id
DIDIT_CLIENT_SECRET=your_didit_client_secret
DIDIT_WORKFLOW_ID=your_didit_workflow_id
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Port for Render / web server binding
# Render injects its own PORT value at runtime, so keep this as 3000 for local dev.
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# ============================================================================
# OPTIONAL: LOGGING & MONITORING
# ============================================================================
# Uncomment and set for production deployments
# LOG_LEVEL=info
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# DATADOG_API_KEY=xxxxx
